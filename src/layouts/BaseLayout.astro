---
const {
  title = 'GitHub Blog',
  description = 'Astro와 GitHub Pages로 운영하는 개인 블로그',
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={baseUrl}>GitHub Blog</a>
      <nav aria-label="Primary navigation">
        <a href={baseUrl}>글</a>
        <a href={`${baseUrl}about/`}>소개</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #fafafa;
    --surface: #ffffff;
    --text: #1c1f24;
    --muted: #68707d;
    --line: #d9dee7;
    --accent: #0f766e;
    --accent-dark: #115e59;
    --code-bg: #f1f5f9;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    line-height: 1.65;
  }

  a {
    color: var(--accent-dark);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    max-width: 920px;
    margin: 0 auto;
    padding: 28px 24px;
    border-bottom: 1px solid var(--line);
  }

  .brand {
    color: var(--text);
    font-size: 1.05rem;
    font-weight: 800;
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 18px;
    font-size: 0.95rem;
  }

  nav a {
    color: var(--muted);
    text-decoration: none;
  }

  main {
    max-width: 920px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  h1,
  h2,
  h3 {
    line-height: 1.25;
    letter-spacing: 0;
  }

  h1 {
    margin: 0 0 14px;
    font-size: clamp(2.1rem, 2rem + 1vw, 3rem);
  }

  h2 {
    margin-top: 42px;
  }

  p {
    margin: 0 0 18px;
  }

  code {
    border-radius: 6px;
    background: var(--code-bg);
    padding: 0.15em 0.35em;
    font-size: 0.92em;
  }

  .lede {
    max-width: 680px;
    color: var(--muted);
    font-size: 1.12rem;
  }

  .post-list {
    display: grid;
    gap: 18px;
    margin-top: 42px;
  }

  .post-card {
    display: block;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    padding: 22px;
    color: var(--text);
    text-decoration: none;
  }

  .post-card:hover {
    border-color: var(--accent);
  }

  .post-card h2 {
    margin: 0 0 8px;
    font-size: 1.25rem;
  }

  .post-meta {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .tag {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 2px 9px;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .post-body {
    max-width: 720px;
  }

  .post-body img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  @media (max-width: 620px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      padding: 22px 18px;
    }

    main {
      padding: 36px 18px 64px;
    }
  }
</style>
